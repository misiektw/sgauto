          </size>
         </property>
         <property name="toolTip">
          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Attach extension script to extract info from save file.&lt;br/&gt;Should be Python script with a function &amp;quot;extract_comment&amp;quot;: 

&lt;pre&gt;&lt;code&gt;
&lt;span style=&quot;color: #569cd6&quot;&gt;def&lt;/span&gt; &lt;span style=&quot;color: #0cdc0a&quot;&gt;extract_comment&lt;/span&gt;(
    file_path: &lt;span style=&quot;color: #569cd6&quot;&gt;str&lt;/span&gt;, 
    all_files: &lt;span style=&quot;color: #569cd6&quot;&gt;dict&lt;/span&gt;, 
    log: &lt;span style=&quot;color: #569cd6&quot;&gt;callback[str] ) &lt;/span&gt;-&gt; &lt;span style=&quot;color: #569cd6&quot;&gt;str&lt;/span&gt;:
    &lt;span style=&quot;color: #6a9955&quot;&gt;# extract 100 characters from file_path&lt;/span&gt;
    &lt;span style=&quot;color: #569cd6&quot;&gt;with&lt;/span&gt; &lt;span style=&quot;color: #569cd6&quot;&gt;open&lt;/span&gt;(file_path) &lt;span style=&quot;color: #569cd6&quot;&gt;as&lt;/span&gt; file:
        extracted_string = file.read(100)
    &lt;span style=&quot;color: #569cd6&quot;&gt;return&lt;/span&gt; extracted_string
&lt;/code&gt;&lt;/pre&gt;

&lt;br/&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
         </property>
         <property name="text">
          <string>Attach</string>
         </property>
        </widget>
       </item>
      </layout>
